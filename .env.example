# Server
NODE_ENV=development
PORT=3000

# Supabase — get these from: Project Settings → Database → Connection string
#
# DATABASE_URL: Transaction pooler (port 6543) for the running API.
#   Mode: Transaction | Add ?pgbouncer=true to the end of the URI.
# DIRECT_URL: Direct connection (port 5432) for Prisma migrations and seeding.
#   Mode: Direct connection
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Optional Supabase project URL and anon key (for future client/auth integrations)
# SUPABASE_URL="https://[PROJECT-REF].supabase.co"
# SUPABASE_ANON_KEY="your-anon-key"

# Seed configuration (optional overrides)
# Use a smaller batch size on Supabase free tier if you hit timeouts (e.g. 2000)
SEED_PRODUCT_COUNT=200000
SEED_BATCH_SIZE=5000
